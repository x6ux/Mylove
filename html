<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chat</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0;}
  :root{
    --bg:#000;--bg-surface:#1c1c1c;--bg-elevated:#262626;
    --border:#363636;--text:#f5f5f5;--text2:#a8a8a8;--text3:#6b6b6b;
    --bubble-them:#262626;--bubble-me:#0095f6;--hover:#1a1a1a;--online:#0095f6;
  }
  body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);height:100dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;}

  /* LOGIN SCREEN */
  .login-screen{width:100%;max-width:360px;padding:40px 32px;display:flex;flex-direction:column;gap:16px;background:var(--bg-surface);border-radius:12px;border:1px solid var(--border);}
  .login-screen h2{font-size:22px;font-weight:600;color:var(--text);text-align:center;margin-bottom:4px;}
  .login-screen p{font-size:13px;color:var(--text2);text-align:center;margin-bottom:8px;}
  .login-screen input{width:100%;background:var(--bg-elevated);border:1px solid var(--border);border-radius:8px;padding:10px 14px;font-size:14px;color:var(--text);outline:none;}
  .login-screen input:focus{border-color:#555;}
  .login-screen input::placeholder{color:var(--text3);}
  .login-btn{width:100%;background:#0095f6;border:none;border-radius:8px;padding:11px;font-size:14px;font-weight:600;color:#fff;cursor:pointer;}
  .login-btn:hover{background:#0085e0;}
  .login-error{font-size:12px;color:#ff4444;text-align:center;display:none;}

  /* MAIN APP */
  .app{display:none;width:100%;max-width:960px;height:100dvh;background:var(--bg);border-left:1px solid var(--border);border-right:1px solid var(--border);}
  .wrap{display:flex;height:100%;}

  /* SIDEBAR */
  .sidebar{width:300px;border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;background:var(--bg);}
  .sb-top{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
  .sb-username{font-size:15px;font-weight:600;color:var(--text);}
  .sb-right{display:flex;gap:8px;align-items:center;}
  .icon-btn{background:none;border:none;cursor:pointer;padding:4px;display:flex;align-items:center;justify-content:center;border-radius:50%;color:var(--text);}
  .icon-btn:hover{background:var(--bg-elevated);}
  .search-wrap{padding:8px 10px;border-bottom:1px solid var(--border);}
  .search-wrap input{width:100%;background:var(--bg-elevated);border:none;border-radius:8px;padding:7px 12px;font-size:13px;color:var(--text);outline:none;}
  .search-wrap input::placeholder{color:var(--text3);}
  .users-list{flex:1;overflow-y:auto;}
  .user-item{display:flex;align-items:center;gap:10px;padding:10px 14px;cursor:pointer;transition:background .1s;}
  .user-item:hover,.user-item.active{background:var(--hover);}
  .avatar{width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:500;flex-shrink:0;position:relative;}
  .avatar-sm{width:38px;height:38px;font-size:13px;}
  .online-ring{position:absolute;bottom:1px;right:1px;width:11px;height:11px;border-radius:50%;background:var(--online);border:2px solid var(--bg);}
  .user-info{flex:1;min-width:0;}
  .user-name{font-size:13px;font-weight:500;color:var(--text);}
  .user-preview{font-size:12px;color:var(--text2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;}
  .unread-badge{min-width:18px;height:18px;border-radius:9px;background:var(--online);color:#fff;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;padding:0 4px;flex-shrink:0;}

  /* CHAT */
  .chat-area{flex:1;display:flex;flex-direction:column;min-width:0;}
  .chat-header{padding:11px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:var(--bg);}
  .chat-header-info{flex:1;min-width:0;}
  .chat-header-name{font-size:14px;font-weight:600;color:var(--text);}
  .chat-header-status{font-size:11px;color:var(--text2);}
  .messages{flex:1;overflow-y:auto;padding:16px 14px;display:flex;flex-direction:column;gap:3px;background:var(--bg);}
  .msg-row{display:flex;align-items:flex-end;gap:6px;}
  .msg-row.me{flex-direction:row-reverse;}
  .bubble{max-width:68%;padding:9px 13px;font-size:14px;line-height:1.5;word-break:break-word;}
  .bubble.them{background:var(--bubble-them);color:var(--text);border-radius:18px 18px 18px 4px;}
  .bubble.me{background:var(--bubble-me);color:#fff;border-radius:18px 18px 4px 18px;}
  .msg-time{font-size:10px;color:var(--text3);margin-bottom:2px;flex-shrink:0;}
  .date-label{text-align:center;margin:10px 0;}
  .date-label span{font-size:11px;color:var(--text3);}
  .input-area{padding:10px 12px;border-top:1px solid var(--border);display:flex;align-items:center;gap:8px;background:var(--bg);}
  .msg-input{flex:1;border:1px solid var(--border);border-radius:20px;padding:9px 14px;font-size:14px;color:var(--text);outline:none;resize:none;font-family:inherit;line-height:1.4;max-height:80px;background:var(--bg-surface);}
  .msg-input::placeholder{color:var(--text3);}
  .msg-input:focus{border-color:#555;}
  .send-btn{background:none;border:none;cursor:pointer;font-size:14px;font-weight:600;color:var(--online);padding:6px 2px;white-space:nowrap;}
  .send-btn:disabled{color:#1a4a7a;cursor:default;}
  .empty-chat{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:var(--bg);}
  .empty-chat svg{opacity:.3;}
  .empty-chat p{font-size:14px;color:var(--text2);}

  /* TYPING */
  .typing-indicator{display:flex;align-items:center;gap:4px;padding:10px 14px;}
  .typing-dot{width:7px;height:7px;border-radius:50%;background:var(--text2);animation:bounce .8s infinite;}
  .typing-dot:nth-child(2){animation-delay:.15s;}
  .typing-dot:nth-child(3){animation-delay:.3s;}
  @keyframes bounce{0%,80%,100%{transform:translateY(0);}40%{transform:translateY(-6px);}}

  /* STATUS BAR */
  .status-bar{height:3px;background:var(--online);position:fixed;top:0;left:0;width:0;transition:width .3s;}

  /* MOBILE */
  @media(max-width:640px){
    .sidebar{width:100%;border-right:none;}
    .sidebar.hidden{display:none;}
    .chat-area.hidden{display:none;}
    #backBtn{display:flex !important;}
    .app{max-width:100%;}
  }
</style>
</head>
<body>

<div class="status-bar" id="statusBar"></div>

<!-- LOGIN -->
<div class="login-screen" id="loginScreen">
  <h2>Chat</h2>
  <p>Enter your name to start chatting</p>
  <input type="text" id="nameInput" placeholder="Your name" maxlength="20">
  <div class="login-error" id="loginError">Please enter your name</div>
  <button class="login-btn" id="loginBtn">Start chatting</button>
</div>

<!-- MAIN APP -->
<div class="app" id="app">
  <div class="wrap">
    <div class="sidebar" id="sidebar">
      <div class="sb-top">
        <span class="sb-username" id="myNameLabel"></span>
        <div class="sb-right">
          <button class="icon-btn" id="logoutBtn" title="Logout">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="search-wrap">
        <input type="text" id="searchInput" placeholder="Search users">
      </div>
      <div class="users-list" id="usersList">
        <div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">Loading users...</div>
      </div>
    </div>

    <div class="chat-area" id="chatArea">
      <div class="empty-chat" id="emptyChat">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--text)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
        </svg>
        <p>Select someone to chat with</p>
      </div>
      <div id="chatView" style="display:none;flex-direction:column;flex:1;min-height:0;">
        <div class="chat-header">
          <button class="icon-btn" id="backBtn" style="display:none;" title="Back">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="avatar avatar-sm" id="chatAvatar"></div>
          <div class="chat-header-info">
            <div class="chat-header-name" id="chatName"></div>
            <div class="chat-header-status" id="chatStatus">Active now</div>
          </div>
        </div>
        <div class="messages" id="messages"></div>
        <div class="input-area">
          <textarea class="msg-input" id="msgInput" placeholder="Message..." rows="1"></textarea>
          <button class="send-btn" id="sendBtn" disabled>Send</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, doc, setDoc, getDoc, onSnapshot, addDoc, query, orderBy, serverTimestamp, updateDoc, where, getDocs } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

// ── FIREBASE CONFIG ──
const firebaseConfig = {
  apiKey: "AIzaSyCGESu1mlPYGthb3ibL6PdD5HpgdjaleF8",
  authDomain: "myloves-ce43d.firebaseapp.com",
  projectId: "myloves-ce43d",
  storageBucket: "myloves-ce43d.firebasestorage.app",
  messagingSenderId: "547760347659",
  appId: "1:547760347659:web:943ef1d86577549ab9c50e"
};

const firebaseApp = initializeApp(firebaseConfig);
const db = getFirestore(firebaseApp);

// ── STATE ──
let myName = '';
let myId = '';
let activeUserId = null;
let activeUserName = '';
let unsubMessages = null;
let unsubUsers = null;
let allUsers = [];

const avatarColors = [
  {bg:'#1e3a5f',text:'#90c4f8'},
  {bg:'#14532d',text:'#86efac'},
  {bg:'#4a1942',text:'#f0abdb'},
  {bg:'#451a03',text:'#fcd0a0'},
  {bg:'#2e1065',text:'#c4b5fd'},
  {bg:'#431407',text:'#fdba74'},
];

function getColor(name) {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = name.charCodeAt(i) + ((h << 5) - h);
  return avatarColors[Math.abs(h) % avatarColors.length];
}

function initials(name) {
  return name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
}

function formatTime(ts) {
  if (!ts) return '';
  const d = ts.toDate ? ts.toDate() : new Date(ts);
  return d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
}

function getChatId(a, b) {
  return [a, b].sort().join('__');
}

// ── LOGIN ──
document.getElementById('loginBtn').addEventListener('click', login);
document.getElementById('nameInput').addEventListener('keydown', e => { if (e.key === 'Enter') login(); });

async function login() {
  const name = document.getElementById('nameInput').value.trim();
  if (!name) {
    document.getElementById('loginError').style.display = 'block';
    return;
  }
  document.getElementById('loginError').style.display = 'none';
  document.getElementById('loginBtn').textContent = 'Connecting...';

  myName = name;
  myId = name.toLowerCase().replace(/\s+/g,'_') + '_' + Math.random().toString(36).slice(2,6);

  // Save user to Firestore
  await setDoc(doc(db, 'users', myId), {
    name: myName,
    id: myId,
    online: true,
    lastSeen: serverTimestamp()
  });

  // Mark offline on close
  window.addEventListener('beforeunload', async () => {
    await setDoc(doc(db, 'users', myId), { online: false, lastSeen: serverTimestamp() }, { merge: true });
  });

  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('myNameLabel').textContent = myName;

  if (window.innerWidth <= 640) {
    document.getElementById('chatArea').classList.add('hidden');
  }

  startListeningUsers();
}

// ── USERS LIST ──
function startListeningUsers() {
  const usersRef = collection(db, 'users');
  unsubUsers = onSnapshot(usersRef, snap => {
    allUsers = [];
    snap.forEach(d => {
      if (d.id !== myId) allUsers.push(d.data());
    });
    renderUsers(document.getElementById('searchInput').value);
  });
}

function renderUsers(filter = '') {
  const list = document.getElementById('usersList');
  const filtered = allUsers.filter(u => u.name.toLowerCase().includes(filter.toLowerCase()));
  if (filtered.length === 0) {
    list.innerHTML = `<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">No users online yet<br><span style="font-size:11px;margin-top:4px;display:block;">Share the link with your friends!</span></div>`;
    return;
  }
  list.innerHTML = '';
  filtered.forEach(u => {
    const c = getColor(u.name);
    const item = document.createElement('div');
    item.className = 'user-item' + (activeUserId === u.id ? ' active' : '');
    item.innerHTML = `
      <div class="avatar" style="background:${c.bg};color:${c.text};">
        ${initials(u.name)}
        ${u.online ? '<div class="online-ring"></div>' : ''}
      </div>
      <div class="user-info">
        <div class="user-name">${u.name}</div>
        <div class="user-preview">${u.online ? 'Active now' : 'Offline'}</div>
      </div>`;
    item.addEventListener('click', () => openChat(u.id, u.name));
    list.appendChild(item);
  });
}

// ── OPEN CHAT ──
function openChat(userId, userName) {
  activeUserId = userId;
  activeUserName = userName;

  renderUsers(document.getElementById('searchInput').value);

  document.getElementById('emptyChat').style.display = 'none';
  document.getElementById('chatView').style.display = 'flex';

  const c = getColor(userName);
  const av = document.getElementById('chatAvatar');
  av.style.background = c.bg;
  av.style.color = c.text;
  av.textContent = initials(userName);
  document.getElementById('chatName').textContent = userName;

  if (window.innerWidth <= 640) {
    document.getElementById('sidebar').classList.add('hidden');
    document.getElementById('chatArea').classList.remove('hidden');
    document.getElementById('backBtn').style.display = 'flex';
  }

  // Unsubscribe old listener
  if (unsubMessages) unsubMessages();

  // Listen to messages
  const chatId = getChatId(myId, userId);
  const msgsRef = collection(db, 'chats', chatId, 'messages');
  const q = query(msgsRef, orderBy('timestamp'));

  document.getElementById('messages').innerHTML = '<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">Loading...</div>';

  unsubMessages = onSnapshot(q, snap => {
    renderMessages(snap.docs.map(d => ({id: d.id, ...d.data()})));
  });
}

// ── RENDER MESSAGES ──
function renderMessages(msgs) {
  const box = document.getElementById('messages');
  if (msgs.length === 0) {
    box.innerHTML = `<div style="padding:20px;text-align:center;font-size:13px;color:var(--text3);">Say hi to start the conversation!</div>`;
    return;
  }
  box.innerHTML = '';
  let lastDate = '';
  msgs.forEach(m => {
    const isMe = m.senderId === myId;
    const time = formatTime(m.timestamp);
    const date = m.timestamp?.toDate ? m.timestamp.toDate().toDateString() : 'Today';
    if (date !== lastDate) {
      lastDate = date;
      const dl = document.createElement('div');
      dl.className = 'date-label';
      dl.innerHTML = `<span>${date === new Date().toDateString() ? 'Today' : date}</span>`;
      box.appendChild(dl);
    }
    const row = document.createElement('div');
    row.className = 'msg-row ' + (isMe ? 'me' : 'them');
    row.innerHTML = `<div class="bubble ${isMe ? 'me' : 'them'}">${escapeHtml(m.text)}</div>${time ? `<span class="msg-time">${time}</span>` : ''}`;
    box.appendChild(row);
  });
  box.scrollTop = box.scrollHeight;
}

function escapeHtml(t) {
  return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── SEND MESSAGE ──
async function sendMsg() {
  const inp = document.getElementById('msgInput');
  const text = inp.value.trim();
  if (!text || !activeUserId) return;

  inp.value = '';
  inp.style.height = 'auto';
  document.getElementById('sendBtn').disabled = true;

  const chatId = getChatId(myId, activeUserId);
  await addDoc(collection(db, 'chats', chatId, 'messages'), {
    text,
    senderId: myId,
    senderName: myName,
    receiverId: activeUserId,
    timestamp: serverTimestamp()
  });
}

// ── EVENT LISTENERS ──
document.getElementById('msgInput').addEventListener('input', function () {
  document.getElementById('sendBtn').disabled = this.value.trim() === '';
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 80) + 'px';
});
document.getElementById('msgInput').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
});
document.getElementById('sendBtn').addEventListener('click', sendMsg);
document.getElementById('searchInput').addEventListener('input', function () { renderUsers(this.value); });
document.getElementById('backBtn').addEventListener('click', () => {
  document.getElementById('sidebar').classList.remove('hidden');
  document.getElementById('chatArea').classList.add('hidden');
  activeUserId = null;
  document.getElementById('chatView').style.display = 'none';
  document.getElementById('emptyChat').style.display = 'flex';
});
document.getElementById('logoutBtn').addEventListener('click', async () => {
  await setDoc(doc(db, 'users', myId), { online: false }, { merge: true });
  location.reload();
});
</script>
</body>
</html>
